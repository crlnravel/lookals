// Shared signing settings.
// Generate local overrides with: ./scripts/setup-signing.sh

LOOKALS_DEVELOPMENT_TEAM =
LOOKALS_BUNDLE_IDENTIFIER = com.lookals.local
LOOKALS_CODE_SIGN_ENTITLEMENTS = Lookals/Lookals.entitlements
LOOKALS_SWIFT_ACTIVE_COMPILATION_CONDITIONS =

